default_platform(:android)

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def version_name
  ENV["APP_VERSION_NAME"] or UI.user_error!("APP_VERSION_NAME env is not set")
end

def version_code
  ENV["APP_VERSION_CODE"] or UI.user_error!("APP_VERSION_CODE env is not set")
end

# ---------------------------------------------------------------------------
# Android — Google Play internal track
# ---------------------------------------------------------------------------
platform :android do
  desc "Build signed AAB and upload to Google Play (internal track)"
  lane :release do
    gradle(
      task: "androidApp:bundleRelease",
      properties: {
        "appVersionName" => version_name,
        "appVersionCode" => version_code,
      },
    )

    upload_to_play_store(
      package_name: "ge.yet.blokblast",
      track: "internal",
      aab: lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH],
      json_key_data: ENV["PLAY_STORE_JSON_KEY"],
      release_status: "draft",
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end
end

# ---------------------------------------------------------------------------
# iOS — TestFlight
# ---------------------------------------------------------------------------
platform :ios do
  desc "Push a new beta build to TestFlight using Manual Signing"
  lane :release do |options|
    setup_ci if ENV["CI"]

    # 1. Setup API Key
    key_id = options[:appstore_key_id] || ENV["APP_STORE_CONNECT_KEY_ID"]
    issuer_id = options[:appstore_issuer_id] || ENV["APP_STORE_CONNECT_ISSUER_ID"]
    key_content = ENV["APP_STORE_CONNECT_KEY_CONTENT"]
    app_identifier = "ge.yet3.blokblast.BlockBlast"

    require "base64"
    require "tmpdir"

    key_path = File.expand_path("AuthKey_#{key_id}.p8", Dir.tmpdir)
    File.write(key_path, Base64.decode64(key_content))

    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: key_path,
      in_house: false
    )

    # 2. Install Certificates and Profiles (Manual Signing)
    if ENV["CI"]
      # setup_ci creates a temporary keychain
      keychain_name = lane_context[SharedValues::KEYCHAIN_PATH]

      # Decode and import the P12 certificate
      p12_path = File.expand_path("dist.p12", Dir.tmpdir)
      File.write(p12_path, Base64.decode64(ENV["IOS_DIST_CERT_P12"]))

      import_certificate(
        certificate_path: p12_path,
        certificate_password: ENV["IOS_DIST_CERT_PASSWORD"],
        keychain_name: keychain_name
      )

      # Decode and install the Provisioning Profile
      profile_path = File.expand_path("app.mobileprovision", Dir.tmpdir)
      File.write(profile_path, Base64.decode64(ENV["IOS_PROVISIONING_PROFILE"]))
      install_provisioning_profile(path: profile_path)
    end

    # 3. Handle Build Number (Increment based on TestFlight)
    begin
      latest_build = latest_testflight_build_number(
        app_identifier: app_identifier,
        api_key: api_key
      )
      new_build_number = latest_build + 1
    rescue
      UI.important("Could not fetch latest build number from TestFlight, using version_code from ENV")
      new_build_number = version_code
    end

    increment_build_number(
      build_number: new_build_number,
      xcodeproj: "iosApp/iosApp.xcodeproj"
    )

    # 4. Build App
    build_app(
      project: "iosApp/iosApp.xcodeproj",
      scheme: "iosApp",
      configuration: "Release",
      api_key: api_key,
      export_method: "app-store",
      xcargs: "MARKETING_VERSION=#{version_name} ",
      export_options: {
        method: "app-store-connect",
        signingStyle: "manual",
        teamID: ENV["APPLE_TEAM_ID"],
        provisioningProfiles: {
          app_identifier => ENV["IOS_PROVISIONING_PROFILE_NAME"]
        }
      },
      output_directory: "build/ios",
      output_name: "Logica.ipa",
      clean: true
    )

    # 5. Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      ipa: "build/ios/Logica.ipa",
      skip_waiting_for_build_processing: true
    )
  end
end
